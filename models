const mongoose = require("mongoose");

const tourSchema = new mongoose.Schema({
    place: {
        type: String,
        required: true
    },
    price: {
        type: Number,
        required: true
    },
    duration: {
        type: String,
        required: true
    },
    date: {
        type: Date,
        required: true
    }
});

module.exports = mongoose.model("Tour", tourSchema);
